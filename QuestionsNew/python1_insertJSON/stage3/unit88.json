            "explanation": "滑动窗口可在 O(n) 时间内维护窗口和。",
            "example": "sliding window",
            "code_segments": {
                "segments": [
                    {
                        "type": "code_block",
                        "lines": [
                            {
                                "type": "code_line",
                                "value": "n,k=map(int,input().split())"
                            },
                            {
                                "type": "code_line",
                                "value": "arr=list(map(int,input().split()))"
                            },
                            {
                                "type": "code_line",
                                "value": "cur=sum(arr[:k])"
                            },
                            {
                                "type": "code_line",
                                "value": "mx=cur"
                            },
                            {
                                "type": "code_line",
                                "value": "for i in range(k,n):"
                            },
                            {
                                "type": "code_line",
                                "value": "    cur += arr[i]-arr[i-k]"
                            },
                            {
                                "type": "code_line",
                                "value": "    mx = max(mx, cur)"
                            },
                            {
                                "type": "code_line",
                                "value": "print(mx)"
                            }
                        ]
                    }
                ]
            }
        },
